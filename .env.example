# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Prisma / PostgreSQL
# Settings > Database > Connection string > URI (Transaction or Session pooler)
DATABASE_URL="postgresql://USER:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="Meu Canga"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# Cron Jobs (Vercel Cron — generate a random secure token)
CRON_SECRET="change-me"
