# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Prisma / PostgreSQL (required for Semana 3 — Escala module and all API routes)
# Use your Supabase direct connection string:
# Settings > Database > Connection string > URI (Transaction or Session pooler)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_NAME=Meu Canga
NEXT_PUBLIC_APP_VERSION=2.0.0

# Cron Jobs (Vercel Cron — gere um token aleatório seguro)
CRON_SECRET=your-cron-secret-here