# =============================================================================
# MeuCanga — Variáveis de ambiente
# Copie para .env.local e preencha os valores reais.
# Nunca commite o .env.local.
# =============================================================================

# ── Banco de dados (Railway PostgreSQL) ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/meucanga"

# ── Supabase ─────────────────────────────────────────────────────────────────
# Painel: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="gere-um-valor-aleatorio-seguro-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MeuCanga"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Painel: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN="APP_USR-..."
MP_WEBHOOK_SECRET="seu-webhook-secret-aqui"

# —— IA / Anthropic —— 
# Console: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Email transacional (Brevo) ────────────────────────────────────────────────
# Painel: https://app.brevo.com → SMTP & API
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="noreply@meu-canga.com"

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
# Envie no header: x-cron-secret ou Authorization: Bearer <valor>
CRON_SECRET="gere-um-valor-aleatorio-seguro-aqui"

# ── Jobs internos ─────────────────────────────────────────────────────────────
# Token para o endpoint /api/internal/jobs/*
JOB_TOKEN="gere-um-valor-aleatorio-seguro-aqui"

# ── Painel Admin (HQ) ────────────────────────────────────────────────────────
# URL secreta do admin: /{ADMIN_PATH} reescrita para /admin
ADMIN_PATH="hq"
ADMIN_USER="admin"
ADMIN_PASS="senha-forte-aqui"
ADMIN_SECRET="gere-um-valor-aleatorio-seguro-aqui"

# ── Cotações de investimentos (Yahoo Finance — sem token necessário) ───────────
# Brapi como fallback opcional: https://brapi.dev
BRAPI_TOKEN=""
