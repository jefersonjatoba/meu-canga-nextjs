// Meu Canga — Prisma Schema
// Regra: campos monetários sempre em centavos (Int). Float proibido para dinheiro.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  cpf           String    @unique
  name          String
  phone         String?
  password      String
  role          String    @default("user") // user, admin
  plan          String    @default("free") // free, pro
  planExpiresAt DateTime?
  horasRasAlvo  Int? // meta de horas RAS por mês
  metaMensal    Int? // meta financeira mensal em centavos
  lastSeenAt    DateTime?
  streakDays    Int       @default(0)
  longestStreak Int       @default(0)
  referralCode  String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscriptions         Subscription[]
  referrals             Referral[]     @relation("Referrer")
  referredByRel         Referral?      @relation("ReferredUser")
  escalas               Escala[]
  escalaConfig          EscalaConfig?
  rasAgendas            RasAgenda[]
  rasAgendamentos       RasAgendamento[]
  rasPagamentos         RasPagamento[]
  rasCenarios           RasCenarioSalvo[]
  rasAuditLogs          RasAuditLog[]
  lancamentos           Lancamento[]
  lancamentoAuditLogs   LancamentoAuditLog[]
  investimentos         Investimento[]
  investimentoAtivos    InvestimentoAtivo[]
  investimentoOperacoes InvestimentoOperacao[]
  metas                 Meta[]
  metaAportes           MetaAporte[]
  recorrencias          Recorrencia[]
  assinaturasCartao     AssinaturaCartao[]
  contas                Conta[]
  categorias            Categoria[]
  faturasCartao         FaturaCartao[]
  comprasCartao         CompraCartao[]
  parcelasCartao        ParcelaCartao[]
  pagamentosFatura      PagamentoFatura[]

  @@index([email])
  @@index([cpf])
}

// ─── MÓDULO: ESCALA ──────────────────────────────────────────────────────────

model Escala {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataEscala   DateTime
  tipoTurno    String // plantao | sobreaviso | extra | folga | ferias
  horaInicio   String   @default("07:00")
  horaFim      String   @default("19:00")
  localServico String?
  observacoes  String?
  alarmeAtivo  Boolean  @default(true)
  status       String   @default("agendada") // agendada | realizada | cancelada
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, dataEscala, horaInicio])
  @@index([userId])
  @@index([dataEscala])
  @@index([status])
}

model EscalaConfig {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo         String // 12x24-12x72 | 12x24-12x48 | 24x48 | 24x72 | 12x36-folgao
  horaInicio   String // HH:mm
  horaFim      String // HH:mm
  inicioCiclo  String // YYYY-MM-DD — âncora do ciclo
  localServico String?
  alarmeAtivo  Boolean  @default(true)
  atualizadoEm DateTime @default(now())
}

// ─── MÓDULO: RAS ─────────────────────────────────────────────────────────────

model RasAgenda {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  data          DateTime
  horaInicio    String
  horaFim       String
  duracao       Int // 6 | 8 | 12 | 24 (horas)
  local         String
  graduacao     String // SD/CB | SGT/SUBTEN
  valorCentavos Int // preço fixado no momento do agendamento
  status        String    @default("agendado") // agendado | realizado | pendente | confirmado | cancelado
  competencia   String // yyyy-MM
  tipo          String    @default("voluntario") // voluntario | compulsorio
  tipoVaga      String    @default("titular") // titular | reserva
  expiresAt     DateTime? // janela de 72h para realizado → pendente
  observacoes   String?
  deletadoEm    DateTime? // soft delete: null = ativo, not null = deletado
  motivoDelecao String?   // por que foi deletado?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  agendamentos RasAgendamento[]
  pagamentos   RasPagamento[]

  // CRITICAL: Índices para 10k clientes / 1M registros
  // Note: @@unique removed — see migrations for partial unique index (WHERE deletadoEm IS NULL)
  @@index([userId, deletadoEm], name: "idx_user_ativo") // WHERE deletadoEm IS NULL
  @@index([data, deletadoEm], name: "idx_data_ativo")
  @@index([status, deletadoEm], name: "idx_status_ativo")
  @@index([competencia, deletadoEm], name: "idx_competencia_ativo")
  @@index([deletadoEm], name: "idx_soft_deletes") // Para queries admin de deletados
  @@index([createdAt], name: "idx_created_for_pagination")

  auditLogs RasAuditLog[]

  // Partial unique index: only active (non-soft-deleted) records can be unique
  // The index is defined in migrations due to Prisma limitations with partial indexes
}

model RasAuditLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rasAgendaId   String
  rasAgenda     RasAgenda @relation(fields: [rasAgendaId], references: [id], onDelete: Cascade)
  acao          String    // criado | atualizado | deletado | marcar_realizado | confirmar | cancelado
  descricao     String    // Descrição amigável da ação
  motivoDelecao String?   // Se deletado, qual foi o motivo?
  dadosAntes    Json?     // Snapshot dos dados antes da mudança
  dadosDepois   Json?     // Snapshot dos dados depois da mudança
  ipAddress     String?   // IP do usuário que fez a ação
  userAgent     String?   // Browser/App info
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([rasAgendaId])
  @@index([acao])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model RasAgendamento {
  id             String    @id @default(cuid())
  rasAgendaId    String
  rasAgenda      RasAgenda @relation(fields: [rasAgendaId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String    @default("agendado")
  dataRealizacao DateTime?
  observacoes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([rasAgendaId])
  @@index([userId])
  @@index([status])
}

model RasPagamento {
  id            String    @id @default(cuid())
  rasAgendaId   String
  rasAgenda     RasAgenda @relation(fields: [rasAgendaId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  valorCentavos Int
  competencia   String // yyyy-MM
  dataPagamento DateTime?
  comprovante   String?
  observacoes   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([rasAgendaId])
  @@index([userId])
  @@index([competencia])
}

model RasCenarioSalvo {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome          String
  descricao     String?
  mes           String // yyyy-MM
  graduacao     String
  eventos       Json
  totalHoras    Int
  totalCentavos Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([mes])
}

// ─── MÓDULO: LANÇAMENTOS ─────────────────────────────────────────────────────
// tipo: income | expense | ras | investment_aporte | investment_resgate | transfer
// source: manual | recorrente | parcelado

model Lancamento {
  id                    String                 @id @default(cuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaId               String
  conta                 Conta                  @relation(fields: [contaId], references: [id], onDelete: Cascade)
  categoriaId           String?
  categoriaRef          Categoria?             @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  descricao             String
  tipo                  String // income | expense | ras | investment_aporte | investment_resgate | transfer
  categoria             String
  valorCentavos         Int // valor em centavos — nunca Float
  data                  DateTime // data do lançamento
  competenciaAt         String? // yyyy-MM — mês de competência (pode diferir da data real)
  source                String                 @default("manual") // manual | recorrente | parcelado
  parcelas              Int? // total de parcelas (se parcelado)
  parcelaAtual          Int? // número da parcela atual (1-based)
  parentId              String? // id da transação-pai (para parcelas filhas)
  parent                Lancamento?            @relation("Parcelas", fields: [parentId], references: [id])
  filhos                Lancamento[]           @relation("Parcelas")
  metaJson              Json? // dados extras (ex.: ras_horas, ativo)
  recorrenciaId         String?
  recorrencia           Recorrencia?           @relation(fields: [recorrenciaId], references: [id])
  status                String                 @default("confirmada") // pendente | confirmada
  idempotencyKey        String?                @unique // previne double-submit
  deletadoEm            DateTime? // soft delete: null = ativo, not null = deletado
  parcelasCartao        ParcelaCartao[]        @relation("ParcelaLancamento")
  pagamentosFatura      PagamentoFatura[]      @relation("PagamentoFaturaLancamento")
  investimentoOperacoes InvestimentoOperacao[] @relation("InvestimentoOperacaoLancamento")
  auditLogs             LancamentoAuditLog[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([userId, recorrenciaId, competenciaAt])
  // Composite indexes for common query patterns (10k users / 1M rows)
  @@index([userId, competenciaAt])
  @@index([userId, competenciaAt, status])
  @@index([userId, tipo, status])
  @@index([userId, contaId, competenciaAt])
  @@index([userId, deletadoEm])
  @@index([userId])
  @@index([contaId])
  @@index([categoriaId])
  @@index([data])
  @@index([competenciaAt])
  @@index([categoria])
  @@index([tipo])
}

model LancamentoAuditLog {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lancamentoId String
  lancamento   Lancamento @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  acao         String     // criado | atualizado | deletado
  dadosAntes   Json?      // snapshot antes da mudança
  dadosDepois  Json?      // snapshot depois da mudança
  ipAddress    String?
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([lancamentoId])
  @@index([userId, createdAt])
}

// MODULO: CATEGORIAS
// tipo: income | expense | both

model Categoria {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome          String
  tipo          String // income | expense | both
  icone         String?
  cor           String?
  ativa         Boolean        @default(true)
  ordem         Int            @default(0)
  lancamentos        Lancamento[]
  comprasCartao      CompraCartao[]
  recorrencias       Recorrencia[]
  assinaturasCartao  AssinaturaCartao[] @relation("AssinaturaCategoria")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, nome, tipo])
  @@index([userId])
  @@index([userId, tipo])
  @@index([userId, ativa])
}

// ─── MÓDULO: CONTAS ──────────────────────────────────────────────────────────
// tipo: checking | savings | credit | investment | wallet | custom

model Conta {
  id                    String                 @id @default(cuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome                  String
  tipo                  String // checking | savings | credit | investment | wallet | custom
  saldoCentavos         Int                    @default(0) // saldo em centavos
  limiteCentavos        Int? // limite de crédito (cartões)
  diaFechamento         Int? // dia de fechamento (cartão de crédito, 1-31)
  diaVencimento         Int? // dia de vencimento da fatura
  banco                 String?
  cor                   String? // hex color para UI
  ativa                 Boolean                @default(true)
  lancamentos           Lancamento[]
  recorrencias          Recorrencia[]
  assinaturasCartao     AssinaturaCartao[]     @relation("AssinaturasCartao")
  faturasCartao         FaturaCartao[]         @relation("CartaoFaturas")
  comprasCartao         CompraCartao[]         @relation("CartaoCompras")
  pagamentosFatura      PagamentoFatura[]      @relation("ContaPagamentoFatura")
  metaAportes           MetaAporte[]
  investimentoOperacoes InvestimentoOperacao[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([userId])
  @@index([ativa])
}

// ─── MÓDULO: INVESTIMENTOS ───────────────────────────────────────────────────

// MODULO: CARTAO DE CREDITO
// status fatura: aberta | fechada | paga | vencida | cancelada
// status compra: ativa | cancelada
// status parcela: prevista | lancada | paga | cancelada
// status pagamento: confirmado | estornado

model FaturaCartao {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaId        String
  conta          Conta             @relation("CartaoFaturas", fields: [contaId], references: [id], onDelete: Restrict)
  competencia    String
  dataFechamento DateTime
  dataVencimento DateTime
  status         String            @default("aberta")
  totalCentavos  Int               @default(0)
  parcelas       ParcelaCartao[]
  pagamentos     PagamentoFatura[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([contaId, competencia])
  @@index([userId])
  @@index([contaId])
  @@index([userId, status])
}

model CompraCartao {
  id                   String            @id @default(cuid())
  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaId              String
  conta                Conta             @relation("CartaoCompras", fields: [contaId], references: [id], onDelete: Restrict)
  categoriaId          String?
  categoriaRef         Categoria?        @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  assinaturaCartaoId   String?
  assinaturaCartao     AssinaturaCartao? @relation("AssinaturaCompras", fields: [assinaturaCartaoId], references: [id], onDelete: SetNull)
  categoria            String
  descricao            String
  valorTotalCentavos   Int
  dataCompra           DateTime
  quantidadeParcelas   Int
  status               String            @default("ativa")
  parcelas             ParcelaCartao[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([userId])
  @@index([contaId])
  @@index([categoriaId])
  @@index([assinaturaCartaoId])
  @@index([userId, status])
}

model ParcelaCartao {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  compraCartaoId String
  compraCartao   CompraCartao @relation(fields: [compraCartaoId], references: [id], onDelete: Restrict)
  faturaCartaoId String
  faturaCartao   FaturaCartao @relation(fields: [faturaCartaoId], references: [id], onDelete: Restrict)
  lancamentoId   String?
  lancamento     Lancamento?  @relation("ParcelaLancamento", fields: [lancamentoId], references: [id], onDelete: SetNull)
  numero         Int
  totalParcelas  Int
  valorCentavos  Int
  competencia    String
  dataVencimento DateTime
  status         String       @default("prevista")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([compraCartaoId, numero])
  @@index([userId])
  @@index([compraCartaoId])
  @@index([faturaCartaoId])
  @@index([lancamentoId])
  @@index([userId, competencia])
}

model PagamentoFatura {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  faturaCartaoId   String
  faturaCartao     FaturaCartao @relation(fields: [faturaCartaoId], references: [id], onDelete: Restrict)
  contaPagamentoId String
  contaPagamento   Conta        @relation("ContaPagamentoFatura", fields: [contaPagamentoId], references: [id], onDelete: Restrict)
  lancamentoId     String?
  lancamento       Lancamento?  @relation("PagamentoFaturaLancamento", fields: [lancamentoId], references: [id], onDelete: SetNull)
  valorCentavos    Int
  dataPagamento    DateTime
  status           String       @default("confirmado")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId])
  @@index([faturaCartaoId])
  @@index([contaPagamentoId])
  @@index([lancamentoId])
  @@index([userId, dataPagamento])
}

model InvestimentoAtivo {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome      String
  ticker    String
  tipo      String
  moeda     String
  corretora String?
  ativo     Boolean                @default(true)
  operacoes InvestimentoOperacao[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([userId])
  @@index([tipo])
  @@index([ativo])
}

model InvestimentoOperacao {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ativoId               String
  ativo                 InvestimentoAtivo @relation(fields: [ativoId], references: [id], onDelete: Restrict)
  contaId               String?
  conta                 Conta?            @relation(fields: [contaId], references: [id], onDelete: SetNull)
  tipo                  String
  quantidadeDecimal     String
  precoUnitarioCentavos Int
  valorTotalCentavos    Int
  taxasCentavos         Int               @default(0)
  dataOperacao          DateTime
  status                String            @default("confirmada")
  lancamentoId          String?
  lancamento            Lancamento?       @relation("InvestimentoOperacaoLancamento", fields: [lancamentoId], references: [id], onDelete: SetNull)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([userId])
  @@index([tipo])
  @@index([ativoId])
  @@index([contaId])
  @@index([lancamentoId])
  @@index([userId, status])
}

model Investimento {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome               String
  tipo               String // ACAO | FUNDO | CRIPTO | RENDA_FIXA
  quantidade         Float // número de cotas/ações — NÃO é dinheiro, Float OK
  precoMedioCentavos Int // preço médio de compra em centavos
  precoAtualCentavos Int? // preço atual de mercado em centavos
  valorCentavos      Int // quantidade × precoAtual (ou precoMedio) em centavos
  dataCompra         DateTime
  observacoes        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([tipo])
}

// ─── MÓDULO: METAS ───────────────────────────────────────────────────────────

model Meta {
  id                   String       @id @default(cuid())
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  descricao            String
  categoria            String // legado: POUPANCA | INVESTIMENTO | LIMITE_DESPESA
  tipo                 String       @default("poupanca") // poupanca | investimento | outro
  valorAlvoCentavos    Int
  valorAtualCentavos   Int          @default(0) // legado/cache; progresso real vem de MetaAporte
  valorInicialCentavos Int          @default(0)
  dataInicio           DateTime
  dataAlvo             DateTime?
  status               String       @default("ativa") // ativa | pausada | concluida | cancelada
  cor                  String?
  icone                String?
  ordem                Int          @default(0)
  aportes              MetaAporte[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model MetaAporte {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaId        String
  meta          Meta     @relation(fields: [metaId], references: [id], onDelete: Cascade)
  contaId       String?
  conta         Conta?   @relation(fields: [contaId], references: [id], onDelete: SetNull)
  valorCentavos Int
  dataAporte    DateTime
  descricao     String?
  status        String   @default("confirmado") // confirmado | cancelado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([metaId])
  @@index([contaId])
  @@index([userId, status])
  @@index([userId, dataAporte])
}

// ─── MÓDULO: RECORRÊNCIAS ────────────────────────────────────────────────────

model Recorrencia {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaId         String
  conta           Conta        @relation(fields: [contaId], references: [id], onDelete: Cascade)
  categoriaId     String?
  categoriaRef    Categoria?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  descricao       String
  tipo            String // income | expense
  categoria       String
  valorCentavos   Int
  frequencia      String // MENSAL | BIMENSAL | TRIMESTRAL | ANUAL
  diaVencimento   Int // 1-31
  dataInicio      DateTime
  dataFim         DateTime?
  proximaExecucao DateTime?
  ultimaExecucao  DateTime?
  ativa           Boolean      @default(true)
  lancamentos     Lancamento[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([categoriaId])
  @@index([ativa])
}

// ─── MÓDULO: ASSINATURAS NO CARTÃO ───────────────────────────────────────────
// Assinaturas recorrentes cobradas em cartão de crédito (Netflix, Spotify, etc.)
// Geram CompraCartao+ParcelaCartao mensalmente via /api/cartao/assinaturas/processar

model AssinaturaCartao {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaId           String
  conta             Conta          @relation("AssinaturasCartao", fields: [contaId], references: [id], onDelete: Restrict)
  categoriaId       String?
  categoriaRef      Categoria?     @relation("AssinaturaCategoria", fields: [categoriaId], references: [id], onDelete: SetNull)
  descricao         String
  categoria         String
  valorCentavos     Int
  diaCobranca       Int            // 1-31 — dia em que a cobrança aparece na fatura
  dataInicio        DateTime
  dataFim           DateTime?
  proximaCobranca   DateTime?
  ultimaCobranca    DateTime?
  ultimaCompetencia String?        // YYYY-MM — última competência gerada (anti-duplicidade)
  ativa             Boolean        @default(true)
  comprasGeradas    CompraCartao[] @relation("AssinaturaCompras")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([contaId])
  @@index([userId, ativa])
  @@index([ativa, proximaCobranca])
}

// ─── PLANOS / ASSINATURAS ────────────────────────────────────────────────────

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String    @default("pro")
  status      String    @default("active")   // active | cancelled | expired | superseded
  source      String    @default("manual")   // manual | mercadopago | trial
  amountCents Int       @default(2990)
  startsAt    DateTime
  endsAt      DateTime?
  paymentRef  String?
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
  @@index([endsAt])
}

// ─── COTAÇÕES ────────────────────────────────────────────────────────────────
// Cache de cotações de ativos financeiros (B3, cripto, etc.)
// Fonte principal: Brapi.dev — TTL de 5 minutos controlado pela API

model CotacaoAtivo {
  id                 String   @id @default(cuid())
  ticker             String   @unique
  nome               String?
  precoCentavos      Int
  fechamentoCentavos Int?
  variacaoPercent    Float?   // variação percentual no dia (ex.: 1.85 = +1,85%)
  fonte              String   @default("brapi")
  atualizadoEm       DateTime @default(now())
  createdAt          DateTime @default(now())

  @@index([ticker])
  @@index([atualizadoEm])
  @@map("cotacao_ativo")
}

// ─── INDICAÇÕES ──────────────────────────────────────────────────────────────

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String   @unique
  rewarded   Boolean  @default(false)
  createdAt  DateTime @default(now())

  referrer   User     @relation("Referrer",     fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User     @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
